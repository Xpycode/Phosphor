<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PhosphorWindows.ViewModels"
        xmlns:views="using:PhosphorWindows.Views"
        x:Class="PhosphorWindows.Views.MainWindow"
        x:DataType="vm:AppViewModel"
        Title="Phosphor"
        Width="1280" Height="800"
        MinWidth="1040" MinHeight="700"
        Icon="/Assets/phosphor.ico">

    <Design.DataContext>
        <vm:AppViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="Auto,5,*,5,Auto">
        <!-- Left Panel: File List -->
        <views:FileListPanel Grid.Column="0"
                            MinWidth="340"
                            Width="400"
                            MaxWidth="440"/>

        <GridSplitter Grid.Column="1"
                     Background="Transparent"
                     ResizeDirection="Columns"/>

        <!-- Center Panel: Preview -->
        <views:PreviewPanel Grid.Column="2"
                           MinWidth="360"/>

        <GridSplitter Grid.Column="3"
                     Background="Transparent"
                     ResizeDirection="Columns"/>

        <!-- Right Panel: Settings -->
        <views:SettingsPanel Grid.Column="4"
                            MinWidth="340"
                            Width="370"
                            MaxWidth="400"/>
    </Grid>
</Window>
